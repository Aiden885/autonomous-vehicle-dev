prefix=/home/dell/environment_dependency/abseil-cpp-master/install
exec_prefix=${prefix}
libdir=/home/dell/environment_dependency/abseil-cpp-master/install/lib
includedir=/home/dell/environment_dependency/abseil-cpp-master/install/include

Name: absl_log_globals
Description: Abseil log_globals library
URL: https://abseil.io/
Version: head
Requires: absl_atomic_hook = head, absl_config = head, absl_core_headers = head, absl_hash = head, absl_log_severity = head, absl_strings = head
Libs: -L${libdir}  -labsl_log_globals
Cflags: -I${includedir} -DNOMINMAX
