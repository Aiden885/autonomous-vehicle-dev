prefix=/home/dell/environment_dependency/abseil-cpp-master/install
exec_prefix=${prefix}
libdir=/home/dell/environment_dependency/abseil-cpp-master/install/lib
includedir=/home/dell/environment_dependency/abseil-cpp-master/install/include

Name: absl_log_internal_format
Description: Abseil log_internal_format library
URL: https://abseil.io/
Version: head
Requires: absl_config = head, absl_core_headers = head, absl_log_internal_config = head, absl_log_internal_globals = head, absl_log_severity = head, absl_strings = head, absl_str_format = head, absl_time = head, absl_span = head
Libs: -L${libdir}  -labsl_log_internal_format
Cflags: -I${includedir} -DNOMINMAX
