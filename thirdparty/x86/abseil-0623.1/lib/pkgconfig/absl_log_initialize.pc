prefix=/home/dell/environment_dependency/abseil-cpp-master/install
exec_prefix=${prefix}
libdir=/home/dell/environment_dependency/abseil-cpp-master/install/lib
includedir=/home/dell/environment_dependency/abseil-cpp-master/install/include

Name: absl_log_initialize
Description: Abseil log_initialize library
URL: https://abseil.io/
Version: head
Requires: absl_config = head, absl_log_globals = head, absl_log_internal_globals = head, absl_time = head
Libs: -L${libdir}  -labsl_log_initialize
Cflags: -I${includedir} -DNOMINMAX
