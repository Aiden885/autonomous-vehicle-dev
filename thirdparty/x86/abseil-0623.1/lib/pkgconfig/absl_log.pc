prefix=/home/dell/environment_dependency/abseil-cpp-master/install
exec_prefix=${prefix}
libdir=/home/dell/environment_dependency/abseil-cpp-master/install/lib
includedir=/home/dell/environment_dependency/abseil-cpp-master/install/include

Name: absl_log
Description: Abseil log library
URL: https://abseil.io/
Version: head
Requires: absl_log_internal_conditions = head, absl_log_internal_message = head, absl_log_internal_strip = head
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX
