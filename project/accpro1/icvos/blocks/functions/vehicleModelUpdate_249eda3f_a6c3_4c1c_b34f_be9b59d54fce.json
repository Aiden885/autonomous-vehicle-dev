      "value": [
        {
          "standard_library_function": false,
          "function_body": "void vehicleModelUpdate(\n    double accel,\n    double dt,\n    VehicleState* state\n)\n{\n    // 读取旧状态\n    double x0 = state->x;\n    double v0 = state->v;\n    double a0 = state->a;\n\n    // ---------- 更新位置 ----------\n    double x1 = x0 + v0 * dt + 0.5 * accel * dt * dt;\n\n    // ---------- 更新速度 ----------\n    double v1 = v0 + accel * dt;\n\n    // ---------- 更新加速度 ----------\n    double a1 = accel;\n\n    // ---------- 写回状态 ----------\n    state->x = x1;\n    state->v = v1;\n    state->a = a1;\n}",
          "function_link_obj": ""
        }
      ]
    },
